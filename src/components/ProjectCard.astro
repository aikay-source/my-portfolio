---
interface Props {
  name?: string;
  title: string;
  image: string;
  client?: string;
  contributions: string[];
  processLabel?: string;
  slug?: string;
  hasBorder?: boolean;
}

const { name, title, image, client, contributions, processLabel = 'CONTRIBUTION', slug, hasBorder = false } = Astro.props;
const href = slug ? `/works/${slug}` : '#';
---

<a href={href} class="reveal flex flex-col gap-[24px] items-start w-full group">
  <!-- Image -->
  <div class:list={[
    "h-[200px] md:h-[300px] w-full overflow-hidden",
    hasBorder && "border border-border-secondary"
  ]}>
    <img
      src={image}
      alt={name || title}
      class="size-full object-cover project-card-image"
      loading="lazy"
    />
  </div>

  <!-- Details -->
  <div class="flex flex-col gap-[24px] items-start w-full">
    <!-- Name + Description -->
    <div class="flex flex-col items-start w-full">
      {name ? (
        <>
          <h3 class="text-[20px] font-semibold leading-[28px] tracking-[-1px] text-content-primary">
            {name}
          </h3>
          <p class="text-[16px] leading-[24px] text-content-secondary">
            {title}
          </p>
        </>
      ) : (
        <h3 class="text-[20px] font-semibold leading-[28px] tracking-[-1px] text-content-primary">
          {title}
        </h3>
      )}
    </div>

    <!-- Contributions -->
    <div class="flex flex-col gap-[8px] items-start">
      <span class="font-mono text-[12px] leading-[16px] text-content-tertiary">
        {processLabel}
      </span>
      <div class="flex items-center gap-[8px]">
        {contributions.map((c, i) => (
          <>
            <span class="text-[16px] leading-[24px] text-content-primary">{c}</span>
            {i < contributions.length - 1 && (
              <span class="size-[4px] rounded-full bg-border-secondary shrink-0"></span>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</a>
