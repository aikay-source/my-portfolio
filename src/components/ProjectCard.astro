---
interface Props {
  title: string;
  date: string;
  number: string;
  image: string;
  slug: string;
}

const { title, date, number, image, slug } = Astro.props;
---

<a href={`/works/${slug}`} class="group flex flex-col gap-xl w-full">
  <!-- Project Image -->
  <div class="w-full overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-auto block transition-transform duration-500 group-hover:scale-[1.02]"
      loading="lazy"
    />
  </div>

  <!-- Project Details -->
  <div class="flex items-center justify-between w-full">
    <div class="flex flex-col">
      <p class="text-body-l text-content-secondary leading-[--text-body-l--line-height]">
        {title}
      </p>
      <p class="text-body-l text-content-secondary leading-[--text-body-l--line-height]">
        {date}
      </p>
    </div>
    <p class="text-body-l text-content-secondary leading-[--text-body-l--line-height]">
      {number}
    </p>
  </div>
</a>
