---
---

<section class="section-border flex flex-col items-center justify-center px-[16px] md:px-[40px] lg:px-[80px] py-[32px] md:py-[64px]">
  <div class="flex w-full max-w-[848px] flex-col-reverse md:flex-row items-start md:items-center md:justify-between gap-[16px] md:gap-0">
    <!-- Content -->
    <div class="flex flex-col gap-[24px] items-start w-full md:w-auto">
      <!-- Name + Label -->
      <div class="load-animate load-animate-delay-3 flex flex-col gap-[4px] items-start">
        <h1 class="text-[20px] md:text-[32px] font-semibold leading-[28px] md:leading-[40px] tracking-[-1px] md:tracking-[-2px] text-content-primary">
          Samuel Nwokolo
        </h1>
        <p class="font-mono text-[12px] leading-[16px] text-content-tertiary">
          PRODUCT DESIGNER
        </p>
      </div>

      <!-- Bio + Buttons -->
      <div class="flex flex-col gap-[24px] items-start">
        <p class="load-animate load-animate-delay-4 w-full md:w-[400px] text-[16px] leading-[24px] text-content-primary">
          I work with founders and product teams to turn messy ideas into clear, conversion-focused designs that work for users and scale with the brand. I believe in designing not just for aesthetics but for usability, simplicity and delight.
        </p>

        <!-- CTA Buttons -->
        <div class="load-animate load-animate-delay-5 flex items-center gap-[16px]">
          <a
            href="mailto:nwokoloikem@gmail.com"
            class="btn-hover flex items-center justify-center border border-border-secondary bg-[var(--bg-primary)] p-[12px]"
          >
            <span class="flex items-center justify-center px-[4px]">
              <span class="font-mono text-[14px] font-semibold leading-[20px] text-content-primary">
                CONTACT
              </span>
            </span>
          </a>
          <a
            href="#"
            class="btn-hover flex items-center justify-center border border-border-secondary bg-[var(--bg-primary)] p-[12px]"
          >
            <span class="flex items-center justify-center gap-[8px]">
              <span class="flex items-center justify-center px-[4px]">
                <span class="font-mono text-[14px] font-semibold leading-[20px] text-content-primary">
                  RESUME
                </span>
              </span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.5 11.5L11.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-content-primary" />
                <path d="M4.5 4.5H11.5V11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-content-primary" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>

    <!-- Profile Image -->
    <div class="load-animate load-animate-delay-4 shrink-0 size-[150px] md:size-[200px] border-[4px] border-border-tertiary overflow-hidden">
      <img
        src="/images/profile.png"
        alt="Samuel Nwokolo"
        class="size-full object-cover object-top"
        width="200"
        height="200"
      />
    </div>
  </div>
</section>
