---
// Hero section: name, subtitle, description, CTAs + profile image
---

<section class="px-6 md:px-8xl py-6xl overflow-hidden">
  <div class="flex flex-col md:flex-row items-center justify-between md:px-[200px] gap-2xl md:gap-0">
    <!-- Left: Content -->
    <div class="flex flex-col gap-xl max-w-[400px]">
      <div class="flex flex-col gap-xs">
        <h1 class="font-heading text-heading-l font-semibold text-white tracking-[--tracking-heading-l] leading-[--text-heading-l--line-height]">
          Samuel Nwokolo
        </h1>
        <p class="text-body-s font-semibold text-content-muted tracking-[--tracking-body] leading-[--text-body-s--line-height] uppercase">
          Product Designer
        </p>
      </div>

      <div class="flex flex-col gap-xl">
        <p class="text-body-l text-content-secondary leading-[--text-body-l--line-height] tracking-[--tracking-body]">
          I craft intuitive digital experiences that bridge the gap between user needs and business goals. With a focus on clean design and thoughtful interactions, I help brands tell their story through purposeful interfaces.
        </p>

        <div class="flex gap-l items-center">
          <a
            href="/works"
            class="border border-border-tertiary px-l py-s text-body-l text-content-secondary hover:text-white hover:border-content-muted transition-colors duration-200"
          >
            View Works
          </a>
          <a
            href="/#contact"
            class="border border-border-tertiary px-l py-s text-body-l text-content-secondary hover:text-white hover:border-content-muted transition-colors duration-200 overflow-hidden"
          >
            Download CV
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Profile Image -->
    <div class="border-4 border-border-tertiary w-[200px] h-[200px] shrink-0 overflow-hidden">
      <img
        src="/images/profile-image.png"
        alt="Samuel Nwokolo"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
  </div>
</section>
