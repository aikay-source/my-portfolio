---
---

<header class="section-border flex w-full items-center justify-between bg-[var(--bg-primary)] px-[16px] md:px-[40px] lg:px-[80px] py-[16px] md:py-[24px]">
  <!-- Logo -->
  <div class="load-animate load-animate-delay-1 px-0 lg:px-[16px]">
    <a href="/">
      <span class="text-[16px] md:text-[20px] font-bold uppercase leading-[0.8] tracking-[-0.44px] text-content-primary whitespace-pre-line">Samuel
Nwokolo</span>
    </a>
  </div>

  <!-- Center Nav Links (hidden on mobile) -->
  <nav class="load-animate load-animate-delay-2 hidden md:flex items-start gap-[16px]">
    <a href="/works" class="nav-link font-mono text-[14px] font-semibold leading-[20px] text-content-tertiary">
      WORK
    </a>
    <a href="/about" class="nav-link font-mono text-[14px] font-semibold leading-[20px] text-content-tertiary">
      ABOUT
    </a>
    <a href="/resume" class="nav-link font-mono text-[14px] font-semibold leading-[20px] text-content-tertiary">
      RESUME
    </a>
  </nav>

  <!-- Right: Toggle + Contact Button -->
  <div class="load-animate load-animate-delay-3 flex items-center gap-[8px] md:gap-[16px] px-0 lg:px-[16px]">
    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="flex md:hidden items-center justify-center p-[4px] text-content-primary"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 12H21M3 6H21M3 18H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Dark/Light Toggle -->
    <div class="flex items-center gap-[8px] rounded-[100px] border border-border-secondary bg-[var(--surface-l0)] p-[4px]">
      <button
        id="theme-light-btn"
        type="button"
        class="flex items-center rounded-[100px] p-[4px] transition-colors"
        aria-label="Switch to light mode"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="8" cy="8" r="3.33" fill="currentColor" />
          <rect x="7.33" y="1" width="1.33" height="2.67" rx="0.67" fill="currentColor" />
          <rect x="7.33" y="12.33" width="1.33" height="2.67" rx="0.67" fill="currentColor" />
          <rect x="12.33" y="7.33" width="2.67" height="1.33" rx="0.67" fill="currentColor" />
          <rect x="1" y="7.33" width="2.67" height="1.33" rx="0.67" fill="currentColor" />
          <rect x="11.77" y="2.82" width="1.33" height="2.67" rx="0.67" transform="rotate(45 11.77 2.82)" fill="currentColor" />
          <rect x="3.28" y="11.31" width="1.33" height="2.67" rx="0.67" transform="rotate(45 3.28 11.31)" fill="currentColor" />
          <rect x="13.18" y="11.77" width="1.33" height="2.67" rx="0.67" transform="rotate(135 13.18 11.77)" fill="currentColor" />
          <rect x="4.69" y="3.28" width="1.33" height="2.67" rx="0.67" transform="rotate(135 4.69 3.28)" fill="currentColor" />
        </svg>
      </button>
      <button
        id="theme-dark-btn"
        type="button"
        class="flex items-center rounded-[100px] bg-surface-l2 p-[4px] shadow-[0px_2px_4px_0px_rgba(0,0,0,0.08),0px_0px_2px_0px_rgba(0,0,0,0.08)] transition-colors"
        aria-label="Switch to dark mode"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 9.27A6 6 0 0 1 6.73 2 6 6 0 1 0 14 9.27Z" fill="currentColor" />
        </svg>
      </button>
    </div>

    <!-- Contact Button (hidden on mobile) -->
    <a
      href="mailto:nwokoloikem@gmail.com"
      class="btn-hover hidden md:flex items-center justify-center border border-border-secondary bg-[var(--bg-primary)] p-[12px]"
    >
      <span class="flex items-center justify-center px-[4px]">
        <span class="font-mono text-[14px] font-semibold leading-[20px] text-content-primary">
          CONTACT
        </span>
      </span>
    </a>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="hidden fixed inset-0 z-50 bg-[var(--bg-primary)] md:hidden">
  <div class="flex items-center justify-between px-[16px] py-[16px]">
    <a href="/">
      <span class="text-[16px] font-bold uppercase leading-[0.8] tracking-[-0.44px] text-content-primary whitespace-pre-line">Samuel
Nwokolo</span>
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="flex items-center justify-center p-[4px] text-content-primary"
      aria-label="Close menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  <nav class="flex flex-col items-start gap-[24px] px-[16px] pt-[32px]">
    <a href="/works" class="font-mono text-[14px] font-semibold leading-[20px] text-content-tertiary">WORK</a>
    <a href="/about" class="font-mono text-[14px] font-semibold leading-[20px] text-content-tertiary">ABOUT</a>
    <a href="/resume" class="font-mono text-[14px] font-semibold leading-[20px] text-content-tertiary">RESUME</a>
    <a href="mailto:nwokoloikem@gmail.com" class="btn-hover flex items-center justify-center border border-border-secondary bg-[var(--bg-primary)] p-[12px]">
      <span class="px-[4px] font-mono text-[14px] font-semibold leading-[20px] text-content-primary">CONTACT</span>
    </a>
  </nav>
</div>

<script>
  function initThemeToggle() {
    const lightBtn = document.getElementById('theme-light-btn');
    const darkBtn = document.getElementById('theme-dark-btn');

    function setTheme(theme: string) {
      document.documentElement.classList.add('no-transitions');
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
      localStorage.setItem('theme', theme);
      updateToggleUI(theme);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.documentElement.classList.remove('no-transitions');
        });
      });
    }

    const shadowClass = 'shadow-[0px_2px_4px_0px_rgba(0,0,0,0.08),0px_0px_2px_0px_rgba(0,0,0,0.08)]';

    function updateToggleUI(theme: string) {
      if (theme === 'light') {
        lightBtn?.classList.add('bg-surface-l2', shadowClass);
        darkBtn?.classList.remove('bg-surface-l2', shadowClass);
      } else {
        darkBtn?.classList.add('bg-surface-l2', shadowClass);
        lightBtn?.classList.remove('bg-surface-l2', shadowClass);
      }
    }

    lightBtn?.addEventListener('click', () => setTheme('light'));
    darkBtn?.addEventListener('click', () => setTheme('dark'));

    const current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    updateToggleUI(current);
  }

  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => {
      menu?.classList.remove('hidden');
    });

    closeBtn?.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });

    // Close menu on link click
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
      });
    });
  }

  initThemeToggle();
  initMobileMenu();
  document.addEventListener('astro:after-swap', () => {
    initThemeToggle();
    initMobileMenu();
  });
</script>
