<script>
  function initThemeToggle() {
    const lightBtn = document.getElementById('theme-light-btn');
    const darkBtn = document.getElementById('theme-dark-btn');
    const menuLightBtn = document.getElementById('menu-theme-light-btn');
    const menuDarkBtn = document.getElementById('menu-theme-dark-btn');

    const shadowClass = 'shadow-[0px_2px_4px_0px_rgba(0,0,0,0.08),0px_0px_2px_0px_rgba(0,0,0,0.08)]';

    function setTheme(theme: string) {
      document.documentElement.classList.add('no-transitions');
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
      localStorage.setItem('theme', theme);
      updateToggleUI(theme);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.documentElement.classList.remove('no-transitions');
        });
      });
    }

    function updateToggleUI(theme: string) {
      // Update both header and mobile menu toggles
      [lightBtn, menuLightBtn].forEach((btn) => {
        if (theme === 'light') {
          btn?.classList.add('bg-surface-l2', shadowClass);
        } else {
          btn?.classList.remove('bg-surface-l2', shadowClass);
        }
      });
      [darkBtn, menuDarkBtn].forEach((btn) => {
        if (theme === 'dark') {
          btn?.classList.add('bg-surface-l2', shadowClass);
        } else {
          btn?.classList.remove('bg-surface-l2', shadowClass);
        }
      });
    }

    lightBtn?.addEventListener('click', () => setTheme('light'));
    darkBtn?.addEventListener('click', () => setTheme('dark'));
    menuLightBtn?.addEventListener('click', () => setTheme('light'));
    menuDarkBtn?.addEventListener('click', () => setTheme('dark'));

    const current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    updateToggleUI(current);
  }

  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');

    let isOpen = false;

    function openMenu() {
      if (!menu || isOpen) return;
      isOpen = true;
      menu.classList.add('is-open');
    }

    function closeMenu() {
      if (!menu || !isOpen) return;
      isOpen = false;
      menu.classList.remove('is-open');
    }

    menuBtn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);

    // Close menu on link click
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Fade out on scroll/swipe
    menu?.addEventListener('touchmove', closeMenu, { passive: true });
    menu?.addEventListener('wheel', closeMenu, { passive: true });
  }

  initThemeToggle();
  initMobileMenu();
  document.addEventListener('astro:after-swap', () => {
    initThemeToggle();
    initMobileMenu();
  });
</script>
