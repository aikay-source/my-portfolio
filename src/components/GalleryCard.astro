---
interface Props {
  title: string;
  image: string;
}

const { title, image } = Astro.props;
---

<div class="flex flex-col gap-[24px] items-start">
  <div class="h-[272px] md:h-[300px] w-full overflow-hidden border border-border-tertiary bg-[var(--card-bg)]">
    <img
      src={image}
      alt={title}
      class="size-full object-cover"
      loading="lazy"
    />
  </div>
  <h3 class="text-[14px] md:text-[16px] font-semibold leading-[20px] md:leading-[24px] tracking-[-0.5px] text-content-primary">
    {title}
  </h3>
</div>
