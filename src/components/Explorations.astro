---
import SectionTitle from './SectionTitle.astro';

const explorations = [
  { id: 1 },
  { id: 2 },
  { id: 3 },
  { id: 4 },
  { id: 5 },
];
---

<section class="px-6 md:px-8xl py-6xl flex flex-col gap-2xl overflow-hidden">
  <SectionTitle title="Explorations" />

  <div class="flex gap-l items-center overflow-x-auto pb-l -mr-6 md:-mr-8xl scrollbar-hide">
    {explorations.map((item) => (
      <div class="w-[240px] md:w-[308px] h-[200px] bg-card-bg shrink-0"></div>
    ))}
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
