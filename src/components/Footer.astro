  <p class="text-body-s leading-[--text-body-s--line-height] text-content-muted">
    &copy; {year} Samuel. All rights reserved.
  </p>
  <div class="flex gap-l items-center">
    <a href="#" class="text-body-s text-content-muted hover:text-white transition-colors duration-200" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
      LinkedIn
    </a>
    <a href="#" class="text-body-s text-content-muted hover:text-white transition-colors duration-200" aria-label="Twitter" target="_blank" rel="noopener noreferrer">
      Twitter
    </a>
    <a href="#" class="text-body-s text-content-muted hover:text-white transition-colors duration-200" aria-label="Dribbble" target="_blank" rel="noopener noreferrer">
      Dribbble
    </a>
  </div>
</footer>
